# ============================================================================
# TRADING MODE (Hard Limits — Never commit real credentials)
# ============================================================================
DRY_RUN=true
LIVE_TRADING_CONFIRMATION=

# ============================================================================
# EXCHANGE CONFIGURATION
# ============================================================================
# CCXT / Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Solana / Helius
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_WALLET_PRIVATE_KEY=
SOLANA_COMMITMENT=confirmed

# ============================================================================
# NOTIFICATIONS
# ============================================================================
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

ENABLE_WEBHOOK=false
WEBHOOK_URL=

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=sqlite:///./crypto_trading.db

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=trading_agent.log

# ============================================================================
# RISK & LIMITS
# ============================================================================
MAX_NOTIONAL_PER_TRADE=1000.00
MAX_DAILY_LOSS=5000.00
MAX_DAILY_DRAWDOWN_PERCENT=10.0
MAX_CONCURRENT_POSITIONS=5
ORDER_COOLDOWN_SECONDS=5

# ============================================================================
# BACKTEST
# ============================================================================
BACKTEST_DATA_DIR=data/cache
BACKTEST_HISTORY_BARS=2000
BACKTEST_TIMEFRAME=1h

# ============================================================================
# MCP SERVER (Claude Integration)
# ============================================================================
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8765
ENABLE_MCP=false

# ============================================================================
# MISC
# ============================================================================
DEBUG=false
